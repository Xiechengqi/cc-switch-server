    { "id": "providers", "label": "Providers" },
    { "id": "shares", "label": "Shares" },
    { "id": "usage", "label": "Usage and pricing" },
    { "id": "settings", "label": "Settings, auth, router, backup" },
    { "id": "universalProviders", "label": "Universal providers" },
    { "id": "accounts", "label": "Accounts, OAuth, quota" },
    { "id": "router", "label": "Router and tunnels" },
    { "id": "failover", "label": "Failover" },
    { "id": "proxy", "label": "Proxy status" }
  ],
  "hiddenFeatures": [
    { "id": "prompts", "label": "Prompts", "reason": "Hidden until token server product need is confirmed" },
    { "id": "sessions", "label": "Session manager", "reason": "Hidden until token server product need is confirmed" }
  ],
  "excludedFeatures": [
    { "id": "skills", "label": "Skills", "reason": "Not part of token server mainline" },
    { "id": "mcp", "label": "MCP", "reason": "Not part of token server mainline" },
    { "id": "openclaw", "label": "OpenClaw workspace/tools/agents", "reason": "Desktop-only workspace feature" },

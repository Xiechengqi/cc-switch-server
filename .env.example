# cc-switch-server real acceptance environment.
# Copy to a private path such as /tmp/cc-switch-server-real.env before filling values.
# Do not commit real tokens, account emails, raw OAuth responses, or provider secrets.

# Local server under test.
SERVER_URL=http://127.0.0.1:15721
CC_SWITCH_SERVER_TOKEN=<server-login-bearer-token>

# Router/market public endpoints.
ROUTER_BASE_URL=https://jptokenswitch.cc
MARKET_URL=https://market.jptokenswitch.cc
DIRECT_SHARE_URL=https://<share-subdomain>.jptokenswitch.cc
DIRECT_CLAUDE_SHARE_URL=
DIRECT_CODEX_SHARE_URL=
DIRECT_GEMINI_SHARE_URL=
MARKET_API_URL=https://<market-api-base>
MARKET_CLAUDE_API_URL=
MARKET_CODEX_API_URL=
MARKET_GEMINI_API_URL=
SHARE_ID=<local-server-share-id>
CLAUDE_SHARE_ID=
CODEX_SHARE_ID=
GEMINI_SHARE_ID=

# Router public API token used by direct share URL and market API URL probes.
# Minimum target permission is share invocation; do not use a router admin token.
ROUTER_API_TOKEN=<router-user-api-token>
ROUTER_API_TOKEN_HEADER=Authorization

# Optional market-specific API token. Leave empty when MARKET_API_URL accepts the router token.
MARKET_API_TOKEN=
MARKET_API_TOKEN_HEADER=

# Probe behavior.
PROBE_MODEL=probe
STREAM_PROBE=0
REQUIRE_STREAM_USAGE=0
RUN_REAL=0
RUN_TESTS=0
RUN_DEPLOYMENT_TESTS=0
RUN_PROBES=0
EVIDENCE_FILE=/tmp/cc-switch-server-evidence/real-acceptance.json
MATRIX_PATH=docs/code-agent-regression-matrix.json
MATRIX_SUMMARY_FILE=

# Low-cost real provider regression inputs. Use short prompts only.
CLAUDE_PROVIDER_TOKEN=<redacted-claude-token-or-account-id>
CODEX_PROVIDER_TOKEN=<redacted-codex-token-or-account-id>
GEMINI_PROVIDER_TOKEN=<redacted-gemini-token-or-account-id>

# OAuth migration validation placeholders. These must be real test accounts before AB5-AB7 can pass.
CODEX_OAUTH_TEST_ACCOUNT=<redacted-chatgpt-plus-or-pro-account>
CODEX_OAUTH_CALLBACK_URL=https://<callback-host>/api/accounts/oauth/callback/codex
CODEX_OAUTH_REFRESH_TOKEN=
CODEX_OAUTH_REFRESH_TOKEN_FIXTURE=
CODEX_OAUTH_INVALID_REFRESH_TOKEN=
CODEX_OAUTH_EXPIRED_ACCESS_TOKEN=
CLAUDE_OAUTH_TEST_ACCOUNT=<redacted-claude-account>
CLAUDE_OAUTH_CALLBACK_URL=https://<callback-host>/api/accounts/oauth/callback/claude
CLAUDE_OAUTH_REFRESH_TOKEN=
CLAUDE_OAUTH_REFRESH_TOKEN_FIXTURE=
GEMINI_OAUTH_TEST_ACCOUNT=<redacted-google-account>
GEMINI_OAUTH_CALLBACK_URL=https://<callback-host>/api/accounts/oauth/callback/gemini
GEMINI_OAUTH_REFRESH_TOKEN=
GEMINI_OAUTH_REFRESH_TOKEN_FIXTURE=
GEMINI_CLI_CREDENTIALS_FIXTURE=
CURSOR_OAUTH_TEST_ACCOUNT=<redacted-cursor-account>
CURSOR_OAUTH_CALLBACK_URL=https://<callback-host>/api/accounts/oauth/callback/cursor
CURSOR_OAUTH_REFRESH_TOKEN_FIXTURE=
CURSOR_API_KEY_FIXTURE=
ANTIGRAVITY_OAUTH_TEST_ACCOUNT=<redacted-google-account>
ANTIGRAVITY_OAUTH_CALLBACK_URL=https://<callback-host>/api/accounts/oauth/callback/antigravity
ANTIGRAVITY_OAUTH_REFRESH_TOKEN_FIXTURE=

# Server-native OAuth request-shape fixtures. Keep secrets in private env only.
CC_SWITCH_SERVER_GEMINI_CLIENT_ID=
CC_SWITCH_SERVER_GEMINI_CLIENT_SECRET=
CC_SWITCH_SERVER_CURSOR_CLIENT_ID=
CC_SWITCH_SERVER_ANTIGRAVITY_CLIENT_ID=
CC_SWITCH_SERVER_ANTIGRAVITY_CLIENT_SECRET=

# Long-tail provider real validation placeholders. These are gates only; filling them does not
# mean the provider can be marked native before non-stream/stream/usage evidence is captured.
GITHUB_COPILOT_TEST_ACCOUNT=<redacted-github-account>
GITHUB_COPILOT_GITHUB_DOMAIN=github.com
GITHUB_COPILOT_TOKEN_FIXTURE=
KIRO_TEST_ACCOUNT=<redacted-builder-id-account>
KIRO_REGION=us-east-1
KIRO_START_URL=https://view.awsapps.com/start
KIRO_REFRESH_TOKEN_FIXTURE=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# Share market grant validation. Token must include market:share_grants:write.
SHARE_MARKET_URL=https://<share-market-base>
SHARE_MARKET_GRANT_TOKEN=<share-market-grant-token>
SHARE_MARKET_GRANT_TOKEN_HEADER=Authorization
SHARE_MARKET_BUYER_EMAIL=<buyer@example.com>
SHARE_MARKET_LISTING_ID=<listing-id>
SHARE_MARKET_ORDER_ID=<order-id>
SHARE_MARKET_APP_TYPE=codex
SHARE_MARKET_GRANT_MODE=add-revoke
SHARE_MARKET_GRANT_REJECT_ACTION=invalid
SHARE_MARKET_GRANT_EXPECTED_STATUS=
SHARE_MARKET_GRANT_POLL_SECONDS=30
SHARE_MARKET_GRANT_POLL_INTERVAL_SECONDS=2
SHARE_MARKET_GRANT_POLL_ATTEMPTS=
SHARE_MARKET_SKIP_BUYER_VISIBILITY=0

# Local bootstrap helpers.
HOST=127.0.0.1
PORT=
CONFIG_DIR=
KEEP_SERVER=1
KEEP_CONFIG_DIR=0
RUN_SMOKE=1
